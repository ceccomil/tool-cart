<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Optional: wipe any inherited sources so it's predictable -->
    <clear />

    <!-- Local source with your packed nupkgs -->
    <add key="LocalPackages" value="../../PackageOutput" />

    <!-- Keep nuget.org as well (remove this if you want *only* the local feed) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <!-- Clear any parent mappings so we fully control things here -->
    <clear />

    <!-- Local source: only for ToolCart packages -->
    <packageSource key="LocalPackages">
      <package pattern="ToolCart" />
      <package pattern="ToolCart.*" />
    </packageSource>

    <!-- Everything else comes from nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>